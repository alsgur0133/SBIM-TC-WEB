<?xml version="1.0" encoding="utf-8"?>
<!-- IIS + iisnode: 모든 요청을 Node(server/index.js)로 전달. 진입 파일이 다르면 path 두 곳 수정 -->
<configuration>
  <system.webServer>
    <modules runAllManagedModulesForAllRequests="true">
      <remove name="WebDAVModule" />
    </modules>
    <defaultDocument enabled="false" />
    <directoryBrowse enabled="false" />
    <handlers>
      <remove name="WebDAV" />
      <add name="iisnode" path="server/index.js" verb="*" modules="iisnode" resourceType="Unspecified" requireAccess="false" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="Redirect HTTP to HTTPS" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="^OFF$" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^(dev|develop)\.yunwootech\.com(:\d+)?$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}{REQUEST_URI}" redirectType="Permanent" />
        </rule>
        <rule name="APIToNode_RequestUri" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_URI}" pattern="^/bracetc/api/" ignoreCase="true" />
          </conditions>
          <action type="Rewrite" url="server/index.js" appendQueryString="true" />
        </rule>
        <rule name="APIToNode" stopProcessing="true">
          <match url="^api/.*" />
          <action type="Rewrite" url="server/index.js" appendQueryString="true" />
        </rule>
        <rule name="APIToNodeSitePath" stopProcessing="true">
          <match url="^bracetc/api/.*" />
          <action type="Rewrite" url="server/index.js" appendQueryString="true" />
        </rule>
        <rule name="Node" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="server/index.js" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
    <iisnode
      nodeProcessCommandLine="&quot;C:\Program Files\nodejs\node.exe&quot;"
      node_env="production" />
  </system.webServer>
</configuration>
