{
  "name": "sbim-tc-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "seed:test1": "node server/seed-test-user.js",
    "seed:project-manager": "node server/seed-project-manager.js",
    "db:dump": "node scripts/pg-dump.cjs",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "postinstall": "node scripts/patch-web-ifc-three.js",
    "rebuild:server": "cd server && npm install && npm rebuild && cd ..",
    "build:all": "npm run build && cd server && npm install --omit=dev && cd ..",
    "start:prod": "node server/index.js",
    "prepare-publish-iis": "node scripts/prepare-publish-iis.cjs",
    "build:iis": "node scripts/build-for-iis.cjs && node scripts/prepare-publish-iis.cjs",
    "deploy:iis": "npm run build:iis",
    "deploy:iis:root": "node scripts/deploy-iis-root.cjs",
    "deploy:iis:server": "node scripts/deploy-iis-to-server.cjs",
    "build:nginx": "node scripts/build-for-nginx.cjs",
    "prepare-publish-nginx": "node scripts/prepare-publish-nginx.cjs",
    "deploy:nginx": "npm run build:nginx && npm run prepare-publish-nginx",
    "git:upload": "node scripts/git-upload-all.cjs"
  },
  "dependencies": {
    "dxf-parser": "^1.1.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^18.3.1",
    "react-router-dom": "^6.21.1",
    "recharts": "^3.7.0",
    "three": "^0.149.0",
    "trimble-connect-workspace-api": "^0.3.34",
    "web-ifc": "^0.0.39",
    "web-ifc-three": "^0.0.126",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/three": "^0.149.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
